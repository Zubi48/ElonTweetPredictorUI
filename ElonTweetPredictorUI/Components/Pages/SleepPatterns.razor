@page "/sleep-patterns"
@rendermode InteractiveServer
@inject ISleepService SleepService

<PageTitle>Sleep / Wake Patterns</PageTitle>

@if (_loading)
{
    <div class="loading-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
        <p class="mt-3 text-muted">Loading sleep data…</p>
    </div>
}
else if (_data is null)
{
    <div class="alert alert-warning mt-3" role="alert">
        <h6 class="alert-heading mb-2">No sleep data available</h6>
        <p class="mb-0">
            The UI cannot find <code>final_output_v2.txt</code> in the shared data volume (<code>/app/data</code>).
            Make sure the Python sleep-analysis script has run at least once.
        </p>
    </div>
}
else
{
    <!-- ── Status bar ── -->
    <div class="status-bar mb-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <span class="badge bg-secondary">SLEEP ANALYSIS v2</span>
                @if (_est is not null)
                {
                    <span class="text-muted small ms-2">@_est.ClockRegime</span>
                }
            </div>
            <div class="text-muted small">Parsed @_data.ParsedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        </div>
    </div>

    @if (_est is not null)
    {
        <!-- ── Headline live estimate ── -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="signal-card @SignalCss(_est.AsleepProbability)">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <div class="signal-icon">@SignalIcon(_est.AsleepProbability)</div>
                        <div>
                            <div class="signal-title">@SignalTitle(_est.AsleepProbability)</div>
                            <div class="signal-detail">
                                Last tweet @_est.LastTweetEst · silent @_est.SilenceSoFar · activity @_est.ActivityTier
                            </div>
                        </div>
                        <div class="ms-auto text-end">
                            <div class="signal-prob">@_est.AsleepProbability.ToString("0.0")%</div>
                            <div class="text-muted small">chance asleep</div>
                            <div class="text-muted small">95% @_est.AsleepLow.ToString("0.0")–@_est.AsleepHigh.ToString("0.0")%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Key probability + next-tweet cards ── -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <div class="metric-card text-center h-100">
                    <div class="metric-label">Awake right now</div>
                    <div class="metric-value text-success">@_est.AwakeProbability.ToString("0.0")%</div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="metric-card text-center h-100">
                    <div class="metric-label">No tweets until 5 AM</div>
                    <div class="metric-value text-info">@_est.NoTweetsUntil5Probability.ToString("0.0")%</div>
                    <div class="text-muted small">95% @_est.NoTweets5Low.ToString("0.0")–@_est.NoTweets5High.ToString("0.0")%</div>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="metric-card text-center h-100">
                    <div class="metric-label">Predicted next tweet</div>
                    <div class="metric-value text-warning">@ShortTime(_est.NextTweetMedian)</div>
                    <div class="text-muted small">median</div>
                </div>
            </div>
        </div>

        <!-- ── Next-tweet detail ── -->
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <h6 class="card-title mb-3">🔮 Next-Tweet Forecast</h6>
                <div class="row g-2 detail-grid">
                    <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">Median</span><span class="detail-value text-warning">@_est.NextTweetMedian</span></div></div>
                    <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">50% interval</span><span class="detail-value">@_est.NextTweet50Interval</span></div></div>
                    <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">90th percentile</span><span class="detail-value">@_est.NextTweet90Pct</span></div></div>
                    @if (!string.IsNullOrWhiteSpace(_est.BranchIfTweetsAgain))
                    {
                        <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">If tweets again</span><span class="detail-value text-success">@_est.BranchIfTweetsAgain</span></div></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_est.BranchIfSilentTillMorning))
                    {
                        <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">If silent till morning</span><span class="detail-value text-danger">@_est.BranchIfSilentTillMorning</span></div></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_est.BranchWeightedMean))
                    {
                        <div class="col-6 col-md-4"><div class="detail-item"><span class="detail-label">Weighted mean</span><span class="detail-value">@_est.BranchWeightedMean</span></div></div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── Per-weekday sleep summary ── -->
    @if (_data.WeekdaySummaries.Count > 0)
    {
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h6 class="card-title mb-0">🛏️ Per-Weekday Sleep Summary</h6>
                    @if (_hasLaunch && _hasNonLaunch)
                    {
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button"
                                    class="btn @(_showLaunch ? "btn-secondary" : "btn-outline-secondary")"
                                    @onclick="() => _showLaunch = false">
                                Non-launch days
                            </button>
                            <button type="button"
                                    class="btn @(_showLaunch ? "btn-outline-secondary" : "btn-secondary")"
                                    @onclick="() => _showLaunch = true">
                                Launch days
                            </button>
                        </div>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm table-striped mb-0 sleep-table">
                        <thead>
                            <tr>
                                <th>Weekday</th>
                                <th>Nights</th>
                                <th>Avg Bedtime</th>
                                <th>Avg Wake-Up</th>
                                <th>Avg Sleep</th>
                                <th>Range</th>
                                <th>Rating</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in WeekdayRows())
                            {
                                <tr>
                                    <td>@w.Weekday</td>
                                    <td class="text-muted">@w.Nights</td>
                                    <td class="text-info">@w.AvgBedtime</td>
                                    <td class="text-success">@w.AvgWakeUp</td>
                                    <td class="@SleepColorClass(w.AvgSleepHours)">@w.AvgSleepHours.ToString("F1") hrs</td>
                                    <td class="text-muted small">@w.MinSleepHours.ToString("F1")–@w.MaxSleepHours.ToString("F1")</td>
                                    <td>@SleepRatingBadge(w.AvgSleepHours)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- ── Down-for-the-night confirmation thresholds ── -->
    @if (_data.Thresholds.Count > 0)
    {
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <div>
                        <h6 class="card-title mb-0">🌙 Down-for-the-Night Thresholds</h6>
                        <div class="text-muted small">Silence after a tweet needed to confirm "no more tweets until 5 AM".</div>
                    </div>
                    <select class="form-select form-select-sm bg-dark text-light border-secondary" style="width:auto"
                            @bind="_thresholdWeekday">
                        @foreach (var d in _thresholdWeekdays)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm table-hover mb-0 sleep-table">
                        <thead>
                            <tr>
                                <th>Last tweet</th>
                                <th>≥ 80%</th>
                                <th>≥ 90%</th>
                                <th>≥ 95%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in ThresholdRows())
                            {
                                <tr>
                                    <td class="text-info">@t.LastTweet</td>
                                    <td>@t.Target80</td>
                                    <td>@t.Target90</td>
                                    <td class="text-warning">@t.Target95</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private bool _loading = true;
    private SleepData? _data;
    private CurrentSleepEstimate? _est;

    private bool _showLaunch;
    private bool _hasLaunch;
    private bool _hasNonLaunch;

    private string _thresholdWeekday = "";
    private string[] _thresholdWeekdays = [];

    protected override async Task OnInitializedAsync()
    {
        _data = await SleepService.GetSleepDataAsync();
        if (_data is not null)
        {
            _est = _data.CurrentEstimate;
            _hasLaunch = _data.WeekdaySummaries.Any(w => w.IsLaunch);
            _hasNonLaunch = _data.WeekdaySummaries.Any(w => !w.IsLaunch);
            // Default to whichever group exists (prefer non-launch).
            _showLaunch = _hasNonLaunch ? false : _hasLaunch;

            _thresholdWeekdays = _data.Thresholds
                .Select(t => t.Weekday)
                .Distinct()
                .ToArray();
            _thresholdWeekday = DefaultThresholdWeekday();
        }
        _loading = false;
    }

    private string DefaultThresholdWeekday()
    {
        // Prefer the weekday referenced in the live estimate, else today, else first available.
        if (_est is not null)
        {
            var match = _thresholdWeekdays.FirstOrDefault(d =>
                _est.NowEst.Contains(d, StringComparison.OrdinalIgnoreCase) ||
                _est.ClockRegime.Contains(d, StringComparison.OrdinalIgnoreCase));
            if (match is not null) return match;
        }
        var today = DateTime.UtcNow.DayOfWeek.ToString();
        return _thresholdWeekdays.FirstOrDefault(d => d == today)
            ?? _thresholdWeekdays.FirstOrDefault()
            ?? "";
    }

    private IEnumerable<WeekdaySleepSummary> WeekdayRows()
    {
        var rows = _data!.WeekdaySummaries.Where(w => w.IsLaunch == _showLaunch);
        return rows.OrderBy(w => WeekdayOrder(w.Weekday));
    }

    private IEnumerable<ConfirmationThreshold> ThresholdRows() =>
        _data!.Thresholds.Where(t => t.Weekday == _thresholdWeekday);

    private static int WeekdayOrder(string weekday) => weekday switch
    {
        "Monday" => 1,
        "Tuesday" => 2,
        "Wednesday" => 3,
        "Thursday" => 4,
        "Friday" => 5,
        "Saturday" => 6,
        "Sunday" => 7,
        _ => 99
    };

    private static string SleepColorClass(double hrs) =>
        hrs < 5 ? "text-danger" : hrs > 7 ? "text-success" : "text-warning";

    private static string SleepRatingBadge(double hrs)
    {
        if (hrs >= 8) return "🌟 Well rested";
        if (hrs >= 6) return "✅ OK";
        if (hrs >= 4) return "⚠️ Short";
        return "🔴 Very short";
    }

    private static string SignalIcon(double asleepPct) => asleepPct switch
    {
        >= 80 => "🌑",
        >= 55 => "🔴",
        >= 45 => "🟠",
        >= 20 => "🟡",
        _ => "🟢"
    };

    private static string SignalTitle(double asleepPct) => asleepPct switch
    {
        >= 80 => "Very likely SLEEPING",
        >= 55 => "Probably sleeping",
        >= 45 => "Uncertain",
        >= 20 => "Probably awake",
        _ => "Very likely AWAKE"
    };

    private static string SignalCss(double asleepPct) => asleepPct switch
    {
        >= 80 => "signal-sleep-strong",
        >= 55 => "signal-sleep",
        >= 45 => "signal-neutral",
        >= 20 => "signal-awake",
        _ => "signal-awake-strong"
    };

    // Reduce "02:18 AM EST (Sat 06/13)" to "02:18 AM" for compact metric tiles.
    private static string ShortTime(string full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "—";
        var idx = full.IndexOf(" EST", StringComparison.OrdinalIgnoreCase);
        return idx > 0 ? full[..idx] : full;
    }
}
