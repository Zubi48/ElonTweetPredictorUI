@page "/hawkes-predictor"
@rendermode InteractiveServer
@inject IHawkesPredictorService HawkesService

<PageTitle>Hawkes Predictor</PageTitle>

@* ── Status bar ── *@
<div class="status-bar mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <span class="badge bg-secondary">HAWKES PREDICTOR</span>
            @if (_health is not null)
            {
                <span class="badge @(_health.HawkesFitted ? "bg-success" : "bg-warning") ms-2">
                    @(_health.HawkesFitted ? "Model Fitted" : "Not Fitted")
                </span>
                <span class="text-muted small ms-2">@_health.DataRows rows</span>
            }
            else if (_healthError)
            {
                <span class="badge bg-danger ms-2">API Unreachable</span>
            }
        </div>
        <div class="text-muted small">Bayesian + Hawkes Process Model</div>
    </div>
</div>

@* ── Input form ── *@
<div class="card bg-dark border-secondary mb-4">
    <div class="card-body">
        <h6 class="card-title mb-3">🔭 Prediction Parameters</h6>
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label small text-muted">Window Start <span class="text-warning">(EST)</span></label>
                <input type="datetime-local" class="form-control form-control-sm bg-dark text-light border-secondary"
                       @bind="_windowStart" />
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label small text-muted">Window End <span class="text-warning">(EST)</span></label>
                <input type="datetime-local" class="form-control form-control-sm bg-dark text-light border-secondary"
                       @bind="_windowEnd" />
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label small text-muted">Momentum Hours</label>
                <input type="number" min="1" max="24" class="form-control form-control-sm bg-dark text-light border-secondary"
                       @bind="_momentumHours" />
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label small text-muted">Hawkes Horizon</label>
                <input type="number" min="1" max="24" class="form-control form-control-sm bg-dark text-light border-secondary"
                       @bind="_hawkesHorizon" />
            </div>
            <div class="col-12 col-lg-2 d-flex align-items-end">
                <button class="btn btn-primary btn-sm w-100" @onclick="RunPrediction" disabled="@_loading">
                    @if (_loading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Predict
                </button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-3 mb-0 py-2 small">@_errorMessage</div>
        }
    </div>
</div>

@* ── Results ── *@
@if (_result is not null)
{
    var fp        = _result.FinalPrediction;
    var pw        = _result.PredictionWindow;
    var comp      = _result.Components;
    var val       = _result.Validation;
    var hp        = _result.HawkesParams;

    @* ── Derived trading signals ── *@
    var signal         = TweetSignal(fp.Tweets);
    var signalColor    = signal switch { "HIGH VOLATILITY" => "danger", "ELEVATED" => "warning", "MODERATE" => "info", _ => "secondary" };
    var signalIcon     = signal switch { "HIGH VOLATILITY" => "🔴", "ELEVATED" => "🟡", "MODERATE" => "🟢", _ => "⚪" };
    var ciWidth        = fp.CiUpper - fp.CiLower;
    var ciPct          = fp.Tweets > 0 ? ciWidth / fp.Tweets * 100.0 : 0;
    var confidence     = ciPct < 20 ? "HIGH" : ciPct < 50 ? "MODERATE" : "LOW";
    var confColor      = confidence == "HIGH" ? "success" : confidence == "MODERATE" ? "warning" : "danger";
    var excitRatio     = hp.Beta > 0 ? hp.Alpha / hp.Beta : 0;
    var excitLabel     = excitRatio >= 1.0 ? "EXPLOSIVE" : excitRatio >= 0.7 ? "HIGH" : excitRatio >= 0.3 ? "MODERATE" : "LOW";
    var excitColor     = excitRatio >= 1.0 ? "danger" : excitRatio >= 0.7 ? "warning" : excitRatio >= 0.3 ? "info" : "secondary";
    var excitPct       = (int)Math.Min(excitRatio * 100, 100);
    var baselinePct    = comp.HawkesHybridTotal > 0 ? comp.DayHourTotal / comp.HawkesHybridTotal * 100.0 : 0;
    var momentumPct    = comp.HawkesHybridTotal > 0 ? comp.HawkesShortTerm / comp.HawkesHybridTotal * 100.0 : 0;
    var momentum       = momentumPct > 40 ? "BURST DRIVEN" : momentumPct > 15 ? "MIXED" : "BASELINE DRIVEN";
    var momentumColor  = momentumPct > 40 ? "warning" : momentumPct > 15 ? "info" : "secondary";
    var modelQuality   = val.HawkesHybridMse < val.DowHodMse ? "Hawkes outperforms baseline" : "Baseline outperforms Hawkes";
    var modelQualColor = val.HawkesHybridMse < val.DowHodMse ? "success" : "warning";
    var hourRates      = _result.PerHourRates
                            .Select(e => e.ValueKind == System.Text.Json.JsonValueKind.Number
                                         ? e.GetDouble()
                                         : e.TryGetProperty("rate", out var r) ? r.GetDouble() : 0.0)
                            .ToList();
    var maxRate        = hourRates.Count > 0 ? hourRates.Max() : 1.0;
    var peakHour       = hourRates.Count > 0 ? hourRates.IndexOf(maxRate) + 1 : 0;

    @* ══ ROW 1: Main trading signal ══ *@
    <div class="card border-@signalColor mb-4" style="background: rgba(0,0,0,0.4);">
        <div class="card-body py-3">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    <div style="font-size:2.8rem; line-height:1;">@signalIcon</div>
                </div>
                <div class="col">
                    <div class="text-muted small mb-1">ACTIVITY SIGNAL · @pw.DayOfWeek · @pw.Hours h window</div>
                    <div class="d-flex align-items-baseline gap-3 flex-wrap">
                        <span class="fs-3 fw-bold text-@signalColor">@signal</span>
                        <span class="fs-5 text-light">@fp.Tweets.ToString("F1") tweets</span>
                        <span class="text-muted small">[@fp.CiLower.ToString("F1") – @fp.CiUpper.ToString("F1")]</span>
                    </div>
                    <div class="mt-2 small">
                        <span class="badge bg-@confColor me-2">@confidence CONFIDENCE</span>
                        <span class="badge bg-@momentumColor me-2">@momentum</span>
                        <span class="badge bg-@excitColor me-2">SELF-EXCITATION @excitLabel</span>
                        @if (!hp.Fitted)
                        {
                            <span class="badge bg-danger">MODEL NOT FITTED — treat as estimate</span>
                        }
                    </div>
                </div>
                <div class="col-12 col-md-auto text-md-end">
                    <div class="text-muted small">What this means for trading</div>
                    <div class="small text-light mt-1" style="max-width:300px;">
                        @TradingInterpretation(signal, confidence, excitLabel, momentum)
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ══ ROW 2: Three key gauges ══ *@
    <div class="row g-3 mb-4">
        @* Predicted activity *@
        <div class="col-12 col-md-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">📢 Expected Activity</span>
                        <span class="badge bg-@signalColor">@signal</span>
                    </div>
                    <div class="fs-2 fw-bold text-@signalColor">@fp.Tweets.ToString("F1")</div>
                    <div class="text-muted small mb-2">tweets in window</div>
                    <div class="progress mb-1" style="height:6px;">
                        <div class="progress-bar bg-@signalColor" style="width:@(Math.Min(fp.Tweets / 15.0 * 100, 100).ToString("F0"))%"></div>
                    </div>
                    <div class="d-flex justify-content-between small text-muted mt-1">
                        <span>min @fp.CiLower.ToString("F1")</span>
                        <span>max @fp.CiUpper.ToString("F1")</span>
                    </div>
                </div>
            </div>
        </div>

        @* Forecast confidence *@
        <div class="col-12 col-md-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">🎯 Forecast Confidence</span>
                        <span class="badge bg-@confColor">@confidence</span>
                    </div>
                    <div class="fs-2 fw-bold text-@confColor">@((100 - ciPct).ToString("F0"))%</div>
                    <div class="text-muted small mb-2">certainty score</div>
                    <div class="progress mb-1" style="height:6px;">
                        <div class="progress-bar bg-@confColor" style="width:@((100 - ciPct).ToString("F0"))%"></div>
                    </div>
                    <div class="small text-muted mt-1">CI spread ±@(ciWidth.ToString("F1")) (@ciPct.ToString("F0")% of forecast)</div>
                </div>
            </div>
        </div>

        @* Self-excitation ratio *@
        <div class="col-12 col-md-4">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="small text-muted">⚡ Self-Excitation (α/β)</span>
                        <span class="badge bg-@excitColor">@excitLabel</span>
                    </div>
                    <div class="fs-2 fw-bold text-@excitColor">@excitRatio.ToString("F2")</div>
                    <div class="text-muted small mb-2">burst amplification ratio</div>
                    <div class="progress mb-1" style="height:6px;">
                        <div class="progress-bar bg-@excitColor" style="width:@excitPct%"></div>
                    </div>
                    <div class="small text-muted mt-1">≥ 1.0 = runaway bursts possible</div>
                </div>
            </div>
        </div>
    </div>

    @* ══ ROW 3: Component drivers + per-hour timeline ══ *@
    <div class="row g-3 mb-4">
        @* Component breakdown *@
        <div class="col-12 col-lg-5">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <h6 class="card-title mb-3">🧩 What's Driving the Prediction</h6>
                    @{
                        var totalForBar = comp.HawkesHybridTotal > 0 ? comp.HawkesHybridTotal : 1.0;
                    }
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">📅 Day/Hour Baseline</span>
                            <span class="fw-semibold">@comp.DayHourTotal.ToString("F2") <span class="text-muted">(@(baselinePct.ToString("F0"))%)</span></span>
                        </div>
                        <div class="progress" style="height:8px;">
                            <div class="progress-bar bg-secondary" style="width:@(Math.Min(baselinePct,100).ToString("F0"))%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">⚡ Hawkes Short-Term Burst</span>
                            <span class="fw-semibold text-warning">@comp.HawkesShortTerm.ToString("F2") <span class="text-muted">(@(momentumPct.ToString("F0"))%)</span></span>
                        </div>
                        <div class="progress" style="height:8px;">
                            <div class="progress-bar bg-warning" style="width:@(Math.Min(momentumPct,100).ToString("F0"))%"></div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">🕐 Remaining Hours Carry</span>
                            <span class="fw-semibold text-info">@comp.HawkesRemainingHoursPred.ToString("F2")</span>
                        </div>
                        <div class="progress" style="height:8px;">
                            <div class="progress-bar bg-info" style="width:@(Math.Min(comp.HawkesRemainingHoursPred / totalForBar * 100, 100).ToString("F0"))%"></div>
                        </div>
                    </div>
                    <div class="border-top border-secondary pt-2 mt-1">
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted fw-semibold">Hybrid Total</span>
                            <span class="fw-bold text-info">@comp.HawkesHybridTotal.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="mt-3 small">
                        <span class="badge bg-@momentumColor">@momentum</span>
                        <span class="text-muted ms-2">
                            @(momentumPct > 40
                                ? "Recent tweet bursts are the dominant force — volatility may spike."
                                : momentumPct > 15
                                    ? "Mixed drivers — moderate elevated risk vs baseline."
                                    : "Baseline pattern dominates — predictable, lower surprise risk.")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* Per-hour activity timeline *@
        <div class="col-12 col-lg-7">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="card-title mb-0">📈 Per-Hour Activity Timeline</h6>
                        @if (peakHour > 0)
                        {
                            <span class="badge bg-warning text-dark small">Peak at h+@peakHour</span>
                        }
                    </div>
                    @if (hourRates.Count > 0)
                    {
                        <div class="d-flex align-items-end gap-1" style="height:80px;">
                            @for (int i = 0; i < hourRates.Count; i++)
                            {
                                var rate    = hourRates[i];
                                var barPct  = maxRate > 0 ? rate / maxRate * 100.0 : 0;
                                var barCol  = i + 1 == peakHour ? "warning" : rate > (maxRate * 0.6) ? "info" : "secondary";
                                <div class="d-flex flex-column align-items-center flex-fill" title="h+@(i+1): @rate.ToString("F2")">
                                    <div class="w-100 rounded-top" style="height:@(barPct.ToString("F0"))%; background-color: var(--bs-@barCol); min-height:4px;"></div>
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-1 mt-1">
                            @for (int i = 0; i < hourRates.Count; i++)
                            {
                                <div class="text-center flex-fill" style="font-size:0.6rem; color:var(--bs-secondary-color);">h+@(i+1)</div>
                            }
                        </div>
                        <div class="d-flex flex-wrap gap-3 mt-2 small">
                            @for (int i = 0; i < hourRates.Count; i++)
                            {
                                var rate   = hourRates[i];
                                var isPeak = i + 1 == peakHour;
                                <span class="@(isPeak ? "text-warning fw-bold" : "text-muted")">h+@(i+1): @rate.ToString("F2")</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">No per-hour data available.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ══ ROW 4: Model quality + Hawkes params ══ *@
    <div class="row g-3 mb-4">
        @* Model quality *@
        <div class="col-12 col-md-5">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <h6 class="card-title mb-3">🏆 Model Quality</h6>
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">Hawkes Hybrid MSE</span>
                            <span class="fw-semibold text-@(val.HawkesHybridMse < val.DowHodMse ? "success" : "warning")">@val.HawkesHybridMse.ToString("F4")</span>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted">DoW/HoD Baseline MSE</span>
                            <span class="fw-semibold text-@(val.DowHodMse < val.HawkesHybridMse ? "success" : "warning")">@val.DowHodMse.ToString("F4")</span>
                        </div>
                    </div>
                    <div class="border-top border-secondary pt-2 mt-2 small">
                        <span class="badge bg-@modelQualColor me-2">@modelQuality</span>
                        <span class="text-muted">@val.CvWindows CV windows</span>
                    </div>
                    <div class="mt-2 small text-muted">
                        @(val.HawkesHybridMse < val.DowHodMse
                            ? "The Hawkes model has lower error — burst dynamics add real predictive value. Trust the excitation signals."
                            : "The day/hour baseline beats Hawkes here — lean on the baseline prediction; burst signals are less reliable this window.")
                    </div>
                </div>
            </div>
        </div>

        @* Hawkes params *@
        <div class="col-12 col-md-7">
            <div class="card bg-dark border-secondary h-100">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        🔬 Process Parameters
                        <span class="badge @(hp.Fitted ? "bg-success" : "bg-danger") ms-2 fw-normal small">
                            @(hp.Fitted ? "fitted" : "NOT FITTED")
                        </span>
                    </h6>
                    <div class="row g-3 small">
                        <div class="col-6 col-md-3">
                            <div class="text-muted">μ (base rate)</div>
                            <div class="fw-semibold text-light">@hp.Mu.ToString("F5")</div>
                            <div class="text-muted" style="font-size:0.65rem;">background intensity</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">α (jump size)</div>
                            <div class="fw-semibold text-warning">@hp.Alpha.ToString("F5")</div>
                            <div class="text-muted" style="font-size:0.65rem;">per-tweet excitation</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">β (decay rate)</div>
                            <div class="fw-semibold text-info">@hp.Beta.ToString("F5")</div>
                            <div class="text-muted" style="font-size:0.65rem;">excitement fade speed</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">τ₀ (time scale)</div>
                            <div class="fw-semibold text-light">@hp.Tau0.ToString("F5")</div>
                            <div class="text-muted" style="font-size:0.65rem;">kernel time unit</div>
                        </div>
                    </div>
                    <div class="border-top border-secondary pt-2 mt-3 small text-muted">
                        α/β = <span class="text-@excitColor fw-semibold">@excitRatio.ToString("F3")</span> — each tweet triggers
                        <span class="text-@excitColor fw-semibold">@(excitRatio.ToString("P0"))</span> as many follow-on tweets.
                        @(excitRatio >= 1.0 ? " ⚠️ Runaway cascade risk." : excitRatio >= 0.7 ? " Elevated burst potential." : " Bursts decay quickly.")
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private HawkesHealthResponse? _health;
    private HawkesPredictResponse? _result;
    private bool _loading;
    private bool _healthError;
    private string _errorMessage = "";

    private DateTime _windowStart = DateTime.Today.AddHours(8);
    private DateTime _windowEnd   = DateTime.Today.AddHours(11);
    private int _momentumHours = 3;
    private int _hawkesHorizon = 2;

    private const string DateFormat = "MM/dd/yyyy HH:mm";

    protected override async Task OnInitializedAsync()
    {
        _health = await HawkesService.GetHealthAsync();
        _healthError = _health is null;
    }

    private async Task RunPrediction()
    {
        _errorMessage = "";

        if (_windowEnd <= _windowStart)
        {
            _errorMessage = "Window end must be after window start.";
            return;
        }

        _loading = true;
        _result = null;

        try
        {
            var request = new HawkesPredictRequest
            {
                WindowStart   = _windowStart.ToString(DateFormat),
                WindowEnd     = _windowEnd.ToString(DateFormat),
                MomentumHours = _momentumHours,
                HawkesHorizon = _hawkesHorizon
            };

            _result = await HawkesService.GetPredictionAsync(request);

            if (_result is null)
                _errorMessage = "The Hawkes predictor API is unreachable or returned an error.";
        }
        finally
        {
            _loading = false;
        }
    }

    private static string TweetSignal(double tweets) => tweets switch
    {
        > 10 => "HIGH VOLATILITY",
        > 5  => "ELEVATED",
        > 2  => "MODERATE",
        _    => "QUIET"
    };

    private static string TradingInterpretation(string signal, string confidence, string excit, string momentum) =>
        (signal, confidence, excit) switch
        {
            ("HIGH VOLATILITY", "HIGH",    _)          => "Strong Elon activity expected — high probability of sharp price moves. Reduce size or avoid new entries.",
            ("HIGH VOLATILITY", _,         "EXPLOSIVE") => "Burst cascade risk. Any tweet could amplify rapidly. Stay out or set tight stops.",
            ("HIGH VOLATILITY", _,         _)           => "Elevated activity likely but uncertain range. Use wider stops and smaller size.",
            ("ELEVATED",        "HIGH",    _)           => "Above-average activity ahead. Watch for news-driven momentum; ideal for reactive scalps.",
            ("ELEVATED",        _,         _)           => "Moderate-high activity. Keep positions lean around key times.",
            ("MODERATE",        "HIGH",    _)           => "Normal-range activity, well-forecasted. Routine session — standard sizing is fine.",
            ("MODERATE",        _,         _)           => "Moderate activity with some uncertainty. No strong bias; watch intraday.",
            _                                           => "Quiet window expected. Low tweet-driven volatility — trend following conditions."
        };
}
