@page "/interval-heatmap"
@rendermode InteractiveServer
@inject IStatusService StatusService

<PageTitle>Interval Forecast Heatmap</PageTitle>

@if (_loading)
{
    <div class="loading-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
        <p class="mt-3 text-muted">Loading forecast data…</p>
    </div>
}
else if (_forecasts.Count == 0)
{
    <div class="alert alert-warning mt-3" role="alert">
        <h6 class="alert-heading mb-2">No bet interval forecasts available</h6>
        <p class="mb-0">
            The predictor has not published any interval forecasts yet.
            Check that the Python predictor container is running and <code>status.json</code> is populated.
        </p>
    </div>
}
else
{
    <!-- Status bar -->
    <div class="status-bar mb-3">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <span class="badge bg-secondary">INTERVAL HEATMAP</span>
                <span class="text-muted small ms-2">
                    @_forecasts.Count active bet@(_forecasts.Count == 1 ? "" : "s") &nbsp;·&nbsp;
                    @_allLabels.Count interval rows
                </span>
            </div>
            <div class="text-muted small">Probability % per interval range</div>
        </div>
    </div>

    <!-- Heatmap card -->
    <div class="card bg-dark border-secondary mb-4">
        <div class="card-body">
            <h6 class="card-title mb-3">🎯 Bet Interval Probability Heatmap</h6>

            <div class="hm-scroll">
                <table class="hm-table">
                    <thead>
                        <tr>
                            <th class="hm-label-col"></th>
                            @foreach (var bet in _forecasts)
                            {
                                <th class="hm-forecast-header">
                                    <div class="hm-forecast-title" title="@bet.Title">@ShortTitle(bet.Title)</div>
                                    <div class="hm-forecast-meta">
                                        <span title="Time remaining">⏳ @bet.TimeRemaining</span>
                                        <span title="Tweets so far">✅ @bet.TweetsInWindow</span>
                                    </div>
                                    <div class="hm-forecast-pred">
                                        🔮 @bet.PredictedTotal
                                        <span class="text-muted" style="font-size:0.62rem;">[@bet.CiLower–@bet.CiUpper] σ≈@bet.Sigma.ToString("F1")</span>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var label in _allLabels)
                        {
                            <tr>
                                <td class="hm-label-col">@label</td>
                                @foreach (var bet in _forecasts)
                                {
                                    var interval = bet.Intervals.FirstOrDefault(i => i.Label == label);
                                    if (interval is null)
                                    {
                                        <td class="hm-cell hm-cell-empty" title="Not applicable for this forecast">—</td>
                                    }
                                    else
                                    {
                                        var intensity = interval.Probability / 100.0;
                                        <td class="hm-cell @(interval.IsPredicted ? "hm-cell-predicted" : "")"
                                            style="@CellStyle(intensity, interval.IsPredicted)"
                                            title="@bet.Title · @label · @interval.Probability.ToString("F1")%@(interval.IsPredicted ? " (predicted winner)" : "")">
                                            <div class="hm-cell-prob">@interval.Probability.ToString("F1")%</div>
                                            @if (interval.IsPredicted)
                                            {
                                                <div class="hm-predicted-badge">◄ PREDICTED</div>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Legend -->
            <div class="d-flex gap-4 mt-3 small text-muted flex-wrap align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <span>0%</span>
                    <div class="hm-legend-gradient"></div>
                    <span>100%</span>
                </div>
                <div class="d-flex align-items-center gap-1">
                    <div class="hm-legend-predicted"></div>
                    <span>Predicted winner</span>
                </div>
                <span class="ms-auto small text-muted">Refreshes with live predictor data</span>
            </div>
        </div>
    </div>

    <!-- Summary cards: top pick per bet -->
    <div class="card bg-dark border-secondary mb-4">
        <div class="card-body">
            <h6 class="card-title mb-3">📌 Top Pick per Forecast</h6>
            <div class="row g-3">
                @foreach (var bet in _forecasts)
                {
                    var top = bet.Intervals.OrderByDescending(i => i.Probability).FirstOrDefault();
                    var predicted = bet.Intervals.FirstOrDefault(i => i.IsPredicted);
                    var agreement = top?.Label == predicted?.Label;
                    <div class="col-sm-6 col-lg-4">
                        <div class="summary-tile">
                            <div class="summary-title" title="@bet.Title">@ShortTitle(bet.Title)</div>
                            <div class="summary-row">
                                <span class="summary-label">Highest prob</span>
                                <span class="summary-val text-info">@(top?.Label ?? "—") &nbsp;<span class="fw-bold">@(top?.Probability.ToString("F1"))%</span></span>
                            </div>
                            <div class="summary-row">
                                <span class="summary-label">Model pick</span>
                                <span class="summary-val" style="color:#58a6ff;">@(predicted?.Label ?? "—") &nbsp;<span class="fw-bold">@(predicted?.Probability.ToString("F1"))%</span></span>
                            </div>
                            <div class="summary-row">
                                <span class="summary-label">Agreement</span>
                                <span class="summary-val @(agreement ? "text-success" : "text-warning")">@(agreement ? "✅ Yes — confident bet" : "⚠️ Diverge — review")</span>
                            </div>
                            <div class="summary-row">
                                <span class="summary-label">Time left</span>
                                <span class="summary-val text-muted">⏳ @bet.TimeRemaining</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<BetIntervalForecast> _forecasts = [];
    private List<string> _allLabels = [];

    protected override async Task OnInitializedAsync()
    {
        var status = await StatusService.GetStatusAsync();
        _forecasts = status?.BetIntervalForecasts ?? [];

        // Build the ordered union of all interval labels, preserving numeric order
        _allLabels = _forecasts
            .SelectMany(f => f.Intervals.Select(i => i.Label))
            .Distinct()
            .OrderBy(l => ParseLabelMin(l))
            .ThenBy(l => l)
            .ToList();

        _loading = false;
    }

    /// <summary>Parses the minimum value from a label like "460-479", "&lt;20", "500+".</summary>
    private static int ParseLabelMin(string label)
    {
        if (label.StartsWith('<'))
            return int.MinValue;
        if (label.EndsWith('+'))
            return int.TryParse(label.TrimEnd('+'), out var v) ? v : int.MaxValue;
        var dash = label.IndexOf('-');
        if (dash > 0 && int.TryParse(label[..dash], out var min))
            return min;
        return int.TryParse(label, out var single) ? single : int.MaxValue;
    }

    /// <summary>Shorten long forecast titles for column headers.</summary>
    private static string ShortTitle(string title)
    {
        // "Elon Musk # tweets May 1 - May 8, 2026?" → "May 1–8"
        // "Elon Musk musk # tweets in May 2026?" → "May 2026"
        var t = title
            .Replace("Elon Musk musk # tweets in ", "")
            .Replace("Elon Musk # tweets ", "")
            .TrimEnd('?')
            .Trim();
        return t.Length > 20 ? t[..20] + "…" : t;
    }

    private static string CellStyle(double intensity, bool isPredicted)
    {
        if (intensity <= 0)
            return "background: rgba(255,255,255,0.04); color: #555;";

        // Blue gradient: low → high intensity maps to dark-navy → accent-blue (#58a6ff)
        var r = (int)(20  + intensity * 68);
        var g = (int)(40  + intensity * 126);
        var b = (int)(80  + intensity * 175);
        var alpha = 0.20 + intensity * 0.80;
        var bg = $"rgba({r},{g},{b},{alpha.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})";

        if (isPredicted)
            return $"background: {bg}; color:#fff; font-weight:700;";

        return $"background: {bg}; color:#fff; font-weight:600;";
    }
}
