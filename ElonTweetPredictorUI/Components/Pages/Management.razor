@page "/management"
@rendermode InteractiveServer
@implements IDisposable
@inject IDataChangeNotifier DataChangeNotifier
@inject IVolumeFileService VolumeFileService

<PageTitle>Management</PageTitle>

<div class="card bg-dark border-secondary mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="card-title mb-0">📂 Volume File Manager</h6>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshVolumeFiles">↻ Refresh</button>
        </div>
        @if (_volumeFiles.Count == 0)
        {
            <div class="small text-muted fst-italic">No files found in the data volume.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-dark table-borderless mb-0">
                    <thead>
                        <tr class="text-muted small">
                            <th>File</th>
                            <th class="text-end">Size</th>
                            <th class="text-end">Modified (UTC)</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in _volumeFiles)
                        {
                            <tr>
                                <td class="small">
                                    <code>@file.FileName</code>
                                    @if (!file.Exists)
                                    {
                                        <span class="badge bg-secondary bg-opacity-50 text-muted ms-1" style="font-size:0.6rem;">not on disk</span>
                                    }
                                </td>
                                <td class="small text-muted text-end text-nowrap">@(file.Exists ? FormatFileSize(file.SizeBytes) : "—")</td>
                                <td class="small text-muted text-end text-nowrap">@(file.Exists ? file.LastModifiedUtc.ToString("MMM dd HH:mm") : "—")</td>
                                <td class="text-end text-nowrap">
                                    @if (file.Exists)
                                    {
                                        <a class="btn btn-outline-info btn-sm me-1"
                                           href="/file-manager/download/@Uri.EscapeDataString(file.FileName)"
                                           download="@file.FileName">⬇</a>
                                    }
                                    @if (file.FileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <button class="btn @(_uploadTargetFile == file.FileName ? "btn-warning" : "btn-outline-warning") btn-sm me-1"
                                                @onclick="() => { _uploadTargetFile = _uploadTargetFile == file.FileName ? null : file.FileName; _fileUploadMessage = null; }"
                                                disabled="@_fileUploadInProgress">📤</button>
                                    }
                                    @if (file.Exists)
                                    {
                                        @if (_confirmDeleteFile == file.FileName)
                                        {
                                            <span class="small text-warning me-1">Delete?</span>
                                            <button class="btn btn-danger btn-sm me-1"
                                                    @onclick="() => OnVolumeFileDeleteConfirmed(file.FileName)"
                                                    disabled="@_fileDeleteInProgress">Yes</button>
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="() => _confirmDeleteFile = null"
                                                    disabled="@_fileDeleteInProgress">No</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => { _confirmDeleteFile = file.FileName; _fileDeleteMessage = null; }">🗑</button>
                                        }
                                    }
                                </td>
                            </tr>
                            @if (_uploadTargetFile == file.FileName)
                            {
                                <tr>
                                    <td colspan="4" class="pt-1 pb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="small text-muted text-nowrap">Replace with:</span>
                                            <InputFile OnChange="e => OnVolumeFileUploadSelected(e, file.FileName)"
                                                       accept=".csv"
                                                       class="form-control form-control-sm"
                                                       disabled="@_fileUploadInProgress" />
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="() => { _uploadTargetFile = null; _fileUploadMessage = null; }"
                                                    disabled="@_fileUploadInProgress">✕</button>
                                        </div>
                                        @if (_fileUploadInProgress)
                                        {
                                            <div class="small text-info mt-1">Uploading...</div>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(_fileUploadMessage))
                                        {
                                            <div class="small mt-1 @(_fileUploadIsError ? "text-danger" : "text-success")">@_fileUploadMessage</div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        @if (_fileDeleteInProgress)
        {
            <div class="small text-info mt-2">Deleting...</div>
        }
        else if (!string.IsNullOrWhiteSpace(_fileDeleteMessage))
        {
            <div class="small mt-2 @(_fileDeleteIsError ? "text-danger" : "text-success")">@_fileDeleteMessage</div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<VolumeFileInfo> _volumeFiles = [];
    private string? _confirmDeleteFile;
    private bool _fileDeleteInProgress;
    private string? _fileDeleteMessage;
    private bool _fileDeleteIsError;
    private string? _uploadTargetFile;
    private bool _fileUploadInProgress;
    private string? _fileUploadMessage;
    private bool _fileUploadIsError;

    protected override void OnInitialized()
    {
        RefreshVolumeFiles();
        DataChangeNotifier.DataChanged += HandleDataChangedAsync;
    }

    private async Task HandleDataChangedAsync()
    {
        await InvokeAsync(() =>
        {
            RefreshVolumeFiles();
            StateHasChanged();
        });
    }

    private void RefreshVolumeFiles()
    {
        _volumeFiles = VolumeFileService.ListFiles();
    }

    private void OnVolumeFileDeleteConfirmed(string fileName)
    {
        _fileDeleteInProgress = true;
        _confirmDeleteFile = null;
        _fileDeleteMessage = null;
        _fileDeleteIsError = false;

        var result = VolumeFileService.DeleteFile(fileName);
        _fileDeleteIsError = !result.Success;
        _fileDeleteMessage = result.Message;
        if (result.Success)
            RefreshVolumeFiles();

        _fileDeleteInProgress = false;
    }

    private async Task OnVolumeFileUploadSelected(InputFileChangeEventArgs e, string targetFileName)
    {
        var file = e.File;
        if (file is null) return;

        _fileUploadInProgress = true;
        _fileUploadMessage = null;
        _fileUploadIsError = false;
        StateHasChanged();

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            var result = await VolumeFileService.ReplaceFileAsync(targetFileName, stream, file.Name);
            _fileUploadIsError = !result.Success;
            _fileUploadMessage = result.Message;
            if (result.Success)
                RefreshVolumeFiles();
        }
        catch (Exception ex)
        {
            _fileUploadIsError = true;
            _fileUploadMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _fileUploadInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024        => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _             => $"{bytes / (1024.0 * 1024):F1} MB"
    };

    public void Dispose()
    {
        DataChangeNotifier.DataChanged -= HandleDataChangedAsync;
    }
}
