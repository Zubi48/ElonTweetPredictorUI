@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject IStatusService StatusService
@inject ILogService LogService
@inject IModelFileService ModelFileService

<PageTitle>Tweet Predictor Dashboard</PageTitle>

@if (_status is null)
{
    <div class="loading-container">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-3 text-muted">Loading predictor data...</p>
    </div>
}
else
{
    <div class="status-bar">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-success">@_status.State.ToUpper()</span>
                <span class="text-muted small ms-2">Last update: @FormatTimestamp(_status.UpdatedAt)</span>
            </div>
            <div class="text-muted small">
                Next refresh in <strong>@_secondsUntilRefresh</strong>s
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-label">Cumulative Tweets</div>
                <div class="metric-value">@_status.CumulativeCount.ToString("N0")</div>
                <div class="metric-sublabel">All-time total</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-label">This Week</div>
                <div class="metric-value">@_status.TweetsThisWeek.ToString("N0")</div>
                <div class="metric-sublabel">Mon–Sun (EST)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-label">Predicted Weekly</div>
                <div class="metric-value text-primary">@_status.Prediction.WeeklyTotal.ToString("N0")</div>
                <div class="metric-sublabel">Bayesian + Event Factor</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="metric-label">Event Factor</div>
                <div class="metric-value @(_status.Prediction.EventFactor >= 0 ? "text-success" : "text-danger")">
                    @(_status.Prediction.EventFactor >= 0 ? "+" : "")@_status.Prediction.EventFactor.ToString("F4")
                </div>
                <div class="metric-sublabel">@(_status.Prediction.EventAdjustmentPct >= 0 ? "+" : "")@_status.Prediction.EventAdjustmentPct.ToString("F1")% adjustment</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card bg-dark border-secondary">
                <div class="card-body">
                    <h6 class="card-title mb-3">📊 Week Progress</h6>
                    <div class="mb-2">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small">@_status.TweetsThisWeek / @_status.Prediction.WeeklyTotal tweets</span>
                            <span class="small">@_status.Prediction.DaysObserved / 7 days observed</span>
                        </div>
                        <div class="progress" style="height: 24px;">
                            <div class="progress-bar bg-primary" role="progressbar" 
                                 style="width: @GetWeekProgressPercent()%" 
                                 aria-valuenow="@_status.TweetsThisWeek" 
                                 aria-valuemin="0" 
                                 aria-valuemax="@_status.Prediction.WeeklyTotal">
                                @GetWeekProgressPercent()%
                            </div>
                        </div>
                    </div>
                    <div class="row g-2 mt-2 small text-muted">
                        <div class="col-md-4">
                            <strong>Bayesian (pre-EF):</strong> @_status.Prediction.BayesianTotal
                        </div>
                        <div class="col-md-4">
                            <strong>95% CI:</strong> @_status.Prediction.CiLower–@_status.Prediction.CiUpper
                        </div>
                        <div class="col-md-4">
                            <strong>Days left:</strong> @_status.Prediction.DaysRemaining
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_status.ActiveTrackings.Count > 0)
    {
        <h5 class="mb-3">📌 Active Polymarket Tracking Windows (@_status.ActiveTrackings.Count)</h5>
        <div class="row g-3 mb-4">
            @foreach (var tracking in _status.ActiveTrackings)
            {
                <div class="col-lg-6">
                    <div class="tracking-card">
                        <div class="tracking-header">
                            <h6 class="mb-1">@tracking.Title</h6>
                            <small class="text-muted">ID: @tracking.Id</small>
                        </div>
                        <div class="tracking-body">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="tracking-stat">
                                        <div class="stat-label">Window</div>
                                        <div class="stat-value small">@FormatDateRange(tracking.StartDate, tracking.EndDate)</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="tracking-stat">
                                        <div class="stat-label">Target</div>
                                        <div class="stat-value">@(tracking.Target?.ToString("N0") ?? "—")</div>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div class="tracking-stat">
                                        <div class="stat-label">Tweets in Window</div>
                                        <div class="stat-value text-primary">@tracking.TweetsInWindow.ToString("N0")</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="tracking-stat">
                                        <div class="stat-label">Progress</div>
                                        <div class="stat-value">@GetProgress(tracking)</div>
                                    </div>
                                </div>
                            </div>

                            @{
                                var pred = ComputeWindowPrediction(tracking);
                            }
                            @if (pred is not null)
                            {
                                <div class="window-prediction mb-3">
                                    <div class="stat-label mb-2">🔮 Window Prediction</div>
                                    <div class="d-flex justify-content-between align-items-baseline mb-1">
                                        <span class="h5 mb-0 text-info">@pred.Value.Predicted.ToString("N0")</span>
                                        <span class="small text-muted">CI: @pred.Value.Lower.ToString("N0")–@pred.Value.Upper.ToString("N0")</span>
                                    </div>
                                    <div class="small text-muted">
                                        @pred.Value.ElapsedDays.ToString("F1")d elapsed · @pred.Value.RemainingDays.ToString("F1")d left · 
                                        @pred.Value.ObservedRate.ToString("F1") tweets/day observed
                                    </div>
                                </div>
                            }

                            @if (tracking.Target.HasValue && pred is not null)
                            {
                                <div class="kelly-calculator">
                                    <div class="stat-label mb-2">💰 Kelly Bet Calculator</div>
                                    <div class="mb-2">
                                        <label class="form-label small">Market YES Price (0-1)</label>
                                        <input type="number" class="form-control form-control-sm" 
                                               step="0.01" min="0.01" max="0.99"
                                               value="@GetMarketPrice(tracking.Id)"
                                               @onchange="@((e) => UpdateMarketPrice(tracking.Id, e.Value?.ToString()))" />
                                    </div>
                                    @{
                                        var betResult = ComputeBet(pred.Value.Predicted, pred.Value.Lower, pred.Value.Upper, tracking.Target.Value, GetMarketPrice(tracking.Id));
                                    }
                                    @if (betResult is not null)
                                    {
                                        <div class="bet-result p-2 rounded" style="background-color: var(--bg-primary);">
                                            <div class="d-flex justify-content-between mb-2">
                                                <span class="bet-stat">
                                                    <strong>@betResult.TierEmoji @betResult.Side</strong>
                                                    <small class="d-block text-muted">@betResult.Tier</small>
                                                </span>
                                                <span class="bet-stat text-end">
                                                    <strong>@betResult.FracKellyPct.ToString("F1")%</strong>
                                                    <small class="d-block text-muted">$@betResult.BetDollars per $100</small>
                                                </span>
                                            </div>
                                            <div class="row g-2 small">
                                                <div class="col-4">
                                                    <div class="text-muted">Our P(YES)</div>
                                                    <div><strong>@betResult.OurProbYesPct%</strong></div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="text-muted">Market P(YES)</div>
                                                    <div><strong>@betResult.MarketProbYesPct%</strong></div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="text-muted">Edge</div>
                                                    <div class="@(betResult.EdgePct >= 0 ? "text-success" : "text-danger")">
                                                        <strong>@(betResult.EdgePct >= 0 ? "+" : "")@betResult.EdgePct%</strong>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-secondary" role="alert">
            <h6 class="alert-heading">📌 No Active Tracking Windows</h6>
            <p class="mb-0">No Polymarket tracking periods are currently active.</p>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary">
                <div class="card-body">
                    <h6 class="card-title mb-3">🤖 Model Health</h6>
                    <table class="table table-sm table-dark table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted">Prior Mean</td>
                                <td class="text-end"><strong>@_status.Model.PriorMean.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Prior Std Dev</td>
                                <td class="text-end"><strong>@_status.Model.PriorStd.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Training Weeks</td>
                                <td class="text-end"><strong>@_status.Model.TrainingWeeks</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Posterior Mean</td>
                                <td class="text-end"><strong>@_status.Prediction.PosteriorMean.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Posterior Std Dev</td>
                                <td class="text-end"><strong>@_status.Prediction.PosteriorStd.ToString("F2")</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary">
                <div class="card-body">
                    <h6 class="card-title mb-3">📁 Data Files</h6>
                    <table class="table table-sm table-dark table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted">CSV</td>
                                <td class="text-end"><code class="small">@System.IO.Path.GetFileName(_status.Files.Csv)</code></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Model</td>
                                <td class="text-end"><code class="small">@System.IO.Path.GetFileName(_status.Files.Model)</code></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Log</td>
                                <td class="text-end"><code class="small">@System.IO.Path.GetFileName(_status.Files.Log)</code></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mt-3 pt-3 border-top border-secondary-subtle">
                        <h6 class="mb-2">🔁 Replace model file</h6>
                        <p class="small text-muted mb-2">
                            Upload a new <code>.pkl</code> file to replace <code>bayesian_model.pkl</code>.
                            The UI will also write <code>reload.flag</code> so the Python service reloads it.
                        </p>
                        <InputFile OnChange="OnModelFileSelected"
                                   accept=".pkl,.plk"
                                   class="form-control form-control-sm"
                                   disabled="@_modelUploadInProgress" />

                        @if (_modelUploadInProgress)
                        {
                            <div class="small text-info mt-2">Uploading model file...</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(_modelUploadMessage))
                        {
                            <div class="small mt-2 @(_modelUploadIsError ? "text-danger" : "text-success")">
                                @_modelUploadMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-dark border-secondary mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="card-title mb-0">📜 Recent Logs (@_logs.Count)</h6>
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn @(_logFilter == "ALL" ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick='() => _logFilter = "ALL"'>All</button>
                    <button type="button" class="btn @(_logFilter == "INFO" ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick='() => _logFilter = "INFO"'>Info</button>
                    <button type="button" class="btn @(_logFilter == "WARNING" ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick='() => _logFilter = "WARNING"'>Warning</button>
                    <button type="button" class="btn @(_logFilter == "ERROR" ? "btn-primary" : "btn-outline-secondary")" 
                            @onclick='() => _logFilter = "ERROR"'>Error</button>
                </div>
            </div>
            <div class="log-viewer">
                @foreach (var log in GetFilteredLogs().TakeLast(50))
                {
                    <div class="log-entry log-@log.Level.ToLower()">
                        <span class="log-time">@FormatTimestamp(log.Timestamp)</span>
                        <span class="log-level badge bg-@GetLogLevelColor(log.Level)">@log.Level</span>
                        <span class="log-logger text-muted">@log.Logger</span>
                        <span class="log-message">@log.Message</span>
                    </div>
                }
                @if (!GetFilteredLogs().Any())
                {
                    <div class="text-muted text-center py-3">No logs available</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private PredictorStatus? _status;
    private List<LogEntry> _logs = [];
    private Timer? _refreshTimer;
    private Timer? _countdownTimer;
    private string _logFilter = "ALL";
    private int _secondsUntilRefresh = 30;
    private Dictionary<string, double> _marketPrices = new();
    private bool _modelUploadInProgress;
    private string? _modelUploadMessage;
    private bool _modelUploadIsError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
        _refreshTimer = new Timer(async _ => await InvokeAsync(async () =>
        {
            await RefreshData();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        _countdownTimer = new Timer(_ => InvokeAsync(() =>
        {
            _secondsUntilRefresh = _secondsUntilRefresh <= 1 ? 30 : _secondsUntilRefresh - 1;
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task RefreshData()
    {
        _status = await StatusService.GetStatusAsync();
        _logs = await LogService.GetRecentLogsAsync(100);
        _secondsUntilRefresh = 30;

        foreach (var tracking in _status?.ActiveTrackings ?? [])
        {
            if (!_marketPrices.ContainsKey(tracking.Id))
            {
                _marketPrices[tracking.Id] = 0.50;
            }
        }
    }

    private IEnumerable<LogEntry> GetFilteredLogs()
    {
        if (_logFilter == "ALL") return _logs;
        return _logs.Where(l => l.Level == _logFilter);
    }

    private string GetLogLevelColor(string level) => level switch
    {
        "ERROR" => "danger",
        "WARNING" => "warning",
        "INFO" => "info",
        _ => "secondary"
    };

    private string FormatTimestamp(string iso8601)
    {
        if (DateTime.TryParse(iso8601, out var dt))
        {
            var local = dt.ToLocalTime();
            return local.ToString("MMM dd HH:mm:ss");
        }
        return iso8601;
    }

    private string FormatDateRange(string start, string end)
    {
        if (DateTime.TryParse(start, out var s) && DateTime.TryParse(end, out var e))
        {
            return $"{s.ToLocalTime():MMM dd} → {e.ToLocalTime():MMM dd}";
        }
        return "—";
    }

    private int GetWeekProgressPercent()
    {
        if (_status is null || _status.Prediction.WeeklyTotal == 0) return 0;
        return Math.Min(100, (int)((double)_status.TweetsThisWeek / _status.Prediction.WeeklyTotal * 100));
    }

    private string GetProgress(ActiveTracking tracking)
    {
        if (!tracking.Target.HasValue || tracking.Target.Value == 0) return "—";
        var pct = Math.Min(100, (int)((double)tracking.TweetsInWindow / tracking.Target.Value * 100));
        return $"{pct}%";
    }

    private (int Predicted, int Lower, int Upper, double ElapsedDays, double RemainingDays, double ObservedRate)? ComputeWindowPrediction(ActiveTracking tracking)
    {
        if (_status is null || !DateTime.TryParse(tracking.StartDate, out var start) || !DateTime.TryParse(tracking.EndDate, out var end))
            return null;

        var now = DateTime.UtcNow;
        var windowDays = Math.Max((end - start).TotalDays, 1.0);
        var elapsedDays = Math.Min(Math.Max((now - start).TotalDays, 0.0), windowDays);
        var remainingDays = Math.Max((end - now).TotalDays, 0.0);

        var observedRate = tracking.TweetsInWindow / Math.Max(elapsedDays, 0.5);
        var bayesianRate = (_status.Prediction.PosteriorMean / 7.0) * (1.0 + _status.Prediction.EventFactor);
        var elapsedFraction = Math.Min(elapsedDays / Math.Max(windowDays, 1.0), 1.0);
        var blendedRate = elapsedFraction * observedRate + (1.0 - elapsedFraction) * bayesianRate;

        var predicted = Math.Max(tracking.TweetsInWindow, (int)Math.Round(tracking.TweetsInWindow + blendedRate * remainingDays));
        var ws = Math.Sqrt(Math.Pow(_status.Prediction.PosteriorStd, 2) * (remainingDays / Math.Max(windowDays, 1.0))) * (1.0 - elapsedFraction * 0.5);
        var lower = Math.Max(tracking.TweetsInWindow, (int)Math.Round(predicted - 1.96 * ws));
        var upper = (int)Math.Round(predicted + 1.96 * ws);

        return (predicted, lower, upper, elapsedDays, remainingDays, observedRate);
    }

    private double GetMarketPrice(string trackingId)
    {
        return _marketPrices.TryGetValue(trackingId, out var price) ? price : 0.50;
    }

    private void UpdateMarketPrice(string trackingId, string? valueStr)
    {
        if (double.TryParse(valueStr, out var value))
        {
            _marketPrices[trackingId] = Math.Clamp(value, 0.01, 0.99);
        }
    }

    private BetResult? ComputeBet(int predicted, int lower, int upper, int target, double marketPrice)
    {
        return KellyCalculator.Calculate(lower, upper, target, marketPrice);
    }

    private async Task OnModelFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }

        _modelUploadInProgress = true;
        _modelUploadMessage = null;
        _modelUploadIsError = false;

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var result = await ModelFileService.ReplaceModelAsync(stream, file.Name);
            _modelUploadIsError = !result.Success;
            _modelUploadMessage = result.Message;

            if (result.Success)
            {
                await RefreshData();
            }
        }
        catch (Exception ex)
        {
            _modelUploadIsError = true;
            _modelUploadMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _modelUploadInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _countdownTimer?.Dispose();
    }
}
