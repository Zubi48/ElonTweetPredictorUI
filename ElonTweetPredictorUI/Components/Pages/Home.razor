@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject IStatusService StatusService
@inject IBetProbabilityService BetProbabilityService
@inject IDataChangeNotifier DataChangeNotifier

<PageTitle>Tweet Predictor Dashboard</PageTitle>

@if (_status is null)
{
    if (!_initialLoadCompleted)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading predictor data...</p>
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <h6 class="alert-heading mb-2">No predictor data available yet</h6>
            <p class="mb-1">The UI is running, but it cannot find <code>tweet_predictor.log</code> in the shared data volume (<code>/app/data</code>).</p>
                <p class="mb-0">Verify both containers are mounted to the same Docker volume (<code>elon-tweet-predictor-data</code>).</p>
        </div>
    }
}
else
{
    <div class="status-bar">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-success">@_status.State.ToUpper()</span>
                <span class="text-muted small ms-2">Last update: @FormatTimestamp(_status.UpdatedAt)</span>
            </div>
            <div class="text-muted small">
                Live updates enabled
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3 mb-4 small">
        <span><span class="text-muted">Cumulative:</span> <strong>@_status.CumulativeCount.ToString("N0")</strong></span>
        <span><span class="text-muted">This week:</span> <strong>@_status.TweetsThisWeek.ToString("N0")</strong></span>
        @if (_status.Prediction.Pace.HasValue)
        {
            <span><span class="text-muted">Pace:</span> <strong class="text-info">@_status.Prediction.Pace.Value.ToString("N0")</strong></span>
        }
        <span><span class="text-muted">Predicted weekly:</span> <strong class="text-primary">@_status.Prediction.WeeklyTotal.ToString("N0")</strong> <span class="text-muted">[@_status.Prediction.CiLower–@_status.Prediction.CiUpper]</span></span>
    </div>

    @if (_betProbabilities is not null && _betProbabilities.Trackings.Count > 0)
    {
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="card-title mb-0">🎲 Bet Probabilities (@_betProbabilities.Trackings.Count)</h6>
                    <span class="small text-muted">Updated: @FormatTimestamp(_betProbabilities.Timestamp)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-dark table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Market</th>
                                <th class="text-end">Tweets</th>
                                <th class="text-end">Predicted</th>
                                <th class="text-end">Progress</th>
                                <th class="text-end">95% CI</th>
                                <th class="text-end">Window</th>
                                @if (_betProbabilities.Trackings.Any(t => t.HasKellyData))
                                {
                                    <th class="text-end">Side</th>
                                    <th class="text-end">Edge</th>
                                    <th class="text-end">Kelly %</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in _betProbabilities.Trackings)
                            {
                                <tr>
                                    <td>
                                        <div>@t.Title</div>
                                        <small class="text-muted">@t.TrackingId[..8]…</small>
                                    </td>
                                    <td class="text-end text-primary"><strong>@t.TweetsInWindow.ToString("N0")</strong></td>
                                    <td class="text-end text-info"><strong>@t.WindowPrediction.ToString("N0")</strong></td>
                                    <td class="text-end" style="min-width: 100px;">
                                        @{ var pct = t.WindowPrediction > 0 ? Math.Min(100, (int)(100.0 * t.TweetsInWindow / t.WindowPrediction)) : 0; }
                                        <div class="progress" style="height: 6px; background: var(--border-color);">
                                            <div class="progress-bar @(pct >= 90 ? "bg-success" : pct >= 50 ? "bg-info" : "bg-primary")" style="width: @pct%"></div>
                                        </div>
                                        <span class="small text-muted">@pct%</span>
                                    </td>
                                    <td class="text-end"><span class="small">@t.WindowCiLower.ToString("N0")–@t.WindowCiUpper.ToString("N0")</span></td>
                                    <td class="text-end"><span class="small">@t.ElapsedDays.ToString("F1")d / @t.WindowDays.ToString("F0")d</span></td>
                                    @if (_betProbabilities.Trackings.Any(bt => bt.HasKellyData))
                                    {
                                        <td class="text-end"><strong>@(t.TierEmoji ?? "") @(t.Side ?? "—")</strong></td>
                                        <td class="text-end @(t.EdgePct >= 0 ? "text-success" : "text-danger")">
                                            @(t.EdgePct is not null ? $"{(t.EdgePct >= 0 ? "+" : "")}{t.EdgePct:F1}%" : "—")
                                        </td>
                                        <td class="text-end">@(t.FracKellyPct?.ToString("F1") ?? "—")%</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary">
                <div class="card-body">
                    <h6 class="card-title mb-3">🤖 Model Health</h6>
                    <table class="table table-sm table-dark table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted">Prior Mean</td>
                                <td class="text-end"><strong>@_status.Model.PriorMean.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Prior Std Dev</td>
                                <td class="text-end"><strong>@_status.Model.PriorStd.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Training Weeks</td>
                                <td class="text-end"><strong>@_status.Model.TrainingWeeks</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Posterior Mean</td>
                                <td class="text-end"><strong>@_status.Prediction.PosteriorMean.ToString("F2")</strong></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Posterior Std Dev</td>
                                <td class="text-end"><strong>@_status.Prediction.PosteriorStd.ToString("F2")</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

}

@code {
    private PredictorStatus? _status;
    private bool _initialLoadCompleted;
    private BetProbabilityEntry? _betProbabilities;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
        DataChangeNotifier.DataChanged += HandleDataChangedAsync;
    }

    private async Task HandleDataChangedAsync()
    {
        await InvokeAsync(async () =>
        {
            await RefreshData();
            StateHasChanged();
        });
    }

    private async Task RefreshData()
    {
        _status = await StatusService.GetStatusAsync();
        _betProbabilities = await BetProbabilityService.GetLatestAsync();
        _initialLoadCompleted = true;
    }

    private string FormatTimestamp(string iso8601)
    {
        if (DateTime.TryParse(iso8601, out var dt))
        {
            var local = dt.ToLocalTime();
            return local.ToString("MMM dd HH:mm:ss");
        }
        return iso8601;
    }

    public void Dispose()
    {
        DataChangeNotifier.DataChanged -= HandleDataChangedAsync;
    }
}
