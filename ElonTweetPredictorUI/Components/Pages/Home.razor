@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject IStatusService StatusService
@inject IDataChangeNotifier DataChangeNotifier
@inject IProbabilityHistoryService ProbabilityHistory

<PageTitle>Tweet Predictor Dashboard</PageTitle>

@if (_status is null)
{
    if (!_initialLoadCompleted)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading predictor data...</p>
        </div>
    }
    else
    {
        <div class="alert alert-warning" role="alert">
            <h6 class="alert-heading mb-2">No predictor data available yet</h6>
            <p class="mb-1">The UI is running, but it cannot find <code>tweet_predictor.log</code> in the shared data volume (<code>/app/data</code>).</p>
                <p class="mb-0">Verify both containers are mounted to the same Docker volume (<code>elon-tweet-predictor-data</code>).</p>
        </div>
    }
}
else
{
    <div class="status-bar">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-success">@_status.State.ToUpper()</span>
                <span class="text-muted small ms-2">Last update: @FormatTimestamp(_status.UpdatedAt)</span>
            </div>
            <div class="text-muted small">
                Live updates enabled
            </div>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-3 mb-4 small">
        <span><span class="text-muted">Cumulative:</span> <strong>@_status.CumulativeCount.ToString("N0")</strong></span>
        <span><span class="text-muted">This week:</span> <strong>@_status.TweetsThisWeek.ToString("N0")</strong></span>
        @if (_status.Prediction.Pace.HasValue)
        {
            <span><span class="text-muted">Pace:</span> <strong class="text-info">@_status.Prediction.Pace.Value.ToString("N0")</strong></span>
        }
        <span><span class="text-muted">Predicted weekly:</span> <strong class="text-primary">@_status.Prediction.WeeklyTotal.ToString("N0")</strong> <span class="text-muted">[@_status.Prediction.CiLower–@_status.Prediction.CiUpper]</span></span>
    </div>

    @if (_status.BetIntervalForecasts.Count > 0)
    {
        <div class="card bg-dark border-secondary mb-4">
            <div class="card-body">
                <h6 class="card-title mb-3">📊 Bet Interval Forecasts</h6>
                <div class="row g-3">
                    @foreach (var bet in _status.BetIntervalForecasts)
                    {
                        <div class="col-lg-6">
                            <div class="tracking-card">
                                <div class="tracking-header">
                                    <div class="fw-semibold small">@bet.Title</div>
                                    <div class="d-flex gap-3 mt-1 small text-muted">
                                        <span>⏳ @bet.TimeRemaining</span>
                                        <span>✅ @bet.TweetsInWindow tweets</span>
                                        <span>🔮 @bet.PredictedTotal <span class="text-muted">[@bet.CiLower–@bet.CiUpper]</span> σ≈@bet.Sigma.ToString("F1")</span>
                                    </div>
                                </div>
                                <div class="tracking-body p-2">
                                    @foreach (var interval in bet.Intervals)
                                    {
                                        var deltas = ProbabilityHistory.GetDeltas(bet.Title, interval.Label);
                                        <div class="d-flex align-items-center gap-2 py-1 px-2 small @(interval.IsPredicted ? "rounded" : "")" style="@(interval.IsPredicted ? "background: rgba(88, 166, 255, 0.1);" : "")">
                                            <span class="text-muted" style="min-width: 60px;">@interval.Label</span>
                                            <div class="flex-grow-1">
                                                <div class="progress" style="height: 10px; background: var(--border-color);">
                                                    <div class="progress-bar @(interval.IsPredicted ? "bg-info" : "bg-secondary")" style="width: @interval.Probability.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                                </div>
                                            </div>
                                            <span class="@(interval.IsPredicted ? "text-info fw-semibold" : "text-muted")" style="min-width: 50px; text-align: right;">@interval.Probability.ToString("F1")%</span>
                                            <span class="delta-badges" style="min-width: 180px; display: inline-flex; gap: 4px; justify-content: flex-end;">
                                                @RenderDelta(deltas.Delta1Hr, "1h")
                                                @RenderDelta(deltas.Delta30Min, "30m")
                                                @RenderDelta(deltas.Delta5Min, "5m")
                                            </span>
                                            @if (interval.IsPredicted) { <span class="text-info">◄</span> }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card bg-dark border-secondary mb-4">
        <div class="card-body">
            <h6 class="card-title mb-3">📈 Anomaly Dashboard</h6>
            <img src="/data-image/anomaly_dashboard.png?v=@_imageKey"
                 class="img-fluid w-100"
                 alt="Anomaly Dashboard"
                 style="border-radius: 4px;" />
        </div>
    </div>

    }

@code {
    private PredictorStatus? _status;
    private bool _initialLoadCompleted;
    private int _imageKey;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
        DataChangeNotifier.DataChanged += HandleDataChangedAsync;
    }

    private async Task HandleDataChangedAsync()
    {
        await InvokeAsync(async () =>
        {
            await RefreshData();
            _imageKey++;
            StateHasChanged();
        });
    }

    private async Task RefreshData()
    {
        _status = await StatusService.GetStatusAsync();
        _initialLoadCompleted = true;
    }

    private RenderFragment RenderDelta(double? delta, string label) => builder =>
    {
        var val = delta ?? 0;
        var css = val > 0 ? "badge bg-success bg-opacity-25 text-success"
                : val < 0 ? "badge bg-danger bg-opacity-25 text-danger"
                          : "badge bg-secondary bg-opacity-25 text-muted";
        var arrow = val > 0 ? "▲" : val < 0 ? "▼" : "";
        var display = val == 0 ? $"{label} 0%" : $"{label} {arrow}{Math.Abs(val):F1}%";

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", css);
        builder.AddAttribute(2, "style", "font-size: 0.6rem; min-width: 52px; text-align: center;");
        builder.AddAttribute(3, "title", $"Change over last {label}");
        builder.AddContent(4, display);
        builder.CloseElement();
    };

    private string FormatTimestamp(string iso8601)
    {
        if (DateTime.TryParse(iso8601, out var dt))
        {
            var local = dt.ToLocalTime();
            return local.ToString("MMM dd HH:mm:ss");
        }
        return iso8601;
    }

    public void Dispose()
    {
        DataChangeNotifier.DataChanged -= HandleDataChangedAsync;
    }
}
